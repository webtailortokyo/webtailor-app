---
import { getLangFromUrl, useTranslations, getRelativePath } from '../i18n/utils';
import type { AppInfo } from '../data/apps';

interface Props {
  app: AppInfo;
}

const { app } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const appName = app.name[lang as keyof typeof app.name] || app.name.ja;
const appDescription = app.description[lang as keyof typeof app.description] || app.description.ja;
---

<a 
  href={getRelativePath(lang, `/${app.id}/`)}
  class="group block bg-white border border-gray-100 rounded-3xl p-8 hover:shadow-xl hover:border-blue-100 transition-all duration-300"
>
  <div class="flex flex-col gap-6">
    <div class="flex items-center justify-between">
      <div class="w-20 h-20 rounded-2xl overflow-hidden shadow-md flex items-center justify-center border border-gray-100 group-hover:scale-105 transition-all duration-300">
        <img src={app.iconUrl} alt={appName} class="w-full h-full object-cover" />
      </div>
      <div class="bg-blue-50 px-4 py-1.5 rounded-full border border-blue-100 transition-colors">
        <span class="text-xs font-bold text-[#3585c7]">NEW</span>
      </div>
    </div>
    
    <div class="space-y-4">
      <h3 class="text-2xl font-bold text-gray-900 group-hover:text-[#3585c7] transition-colors">{appName}</h3>
      <p class="text-gray-500 leading-relaxed min-h-[4.5rem]">
        {appDescription}
      </p>
    </div>

    <div class="flex items-center gap-2 text-sm font-bold text-[#3585c7] group-hover:translate-x-1 transition-transform">
      Learn more
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
      </svg>
    </div>
  </div>
</a>
