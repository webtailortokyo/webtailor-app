---
import { getLangFromUrl, useTranslations, getRelativePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();
---

<footer class="mt-auto bg-white border-t border-gray-100 py-12 px-4">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
    <div class="flex flex-col gap-2 items-center md:items-start">
      <a href={getRelativePath(lang, '/')} class="flex items-center gap-2">
        <img src="/images/header-logo.svg" alt="WEBテーラー" class="h-8 w-auto opacity-80 hover:opacity-100 transition-opacity" />
      </a>
    </div>

    <div class="flex flex-col gap-4 items-center md:items-end">
      <div class="flex flex-wrap justify-center gap-6">
        <a href={getRelativePath(lang, '/')} class="text-sm text-gray-600 hover:text-[#3585c7] transition-colors">{t('nav.home')}</a>
        <a href={getRelativePath(lang, '/privacy/')} class="text-sm text-gray-600 hover:text-[#3585c7] transition-colors">{t('nav.privacy')}</a>
        <a href={getRelativePath(lang, '/terms/')} class="text-sm text-gray-600 hover:text-[#3585c7] transition-colors">{t('nav.terms')}</a>
        <a href={getRelativePath(lang, '/contact/')} class="text-sm text-gray-600 hover:text-[#3585c7] transition-colors">{t('nav.contact')}</a>
      </div>
      <p class="text-xs text-gray-400">
        &copy; {currentYear} {lang === 'ja' ? 'WEBテーラー' : 'WEB TAILOR'}. {t('footer.rights')}
      </p>
    </div>
  </div>
</footer>
