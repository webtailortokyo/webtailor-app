---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import { apps } from '../../../data/apps';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const app = apps.find(a => a.id === 'money-memo')!;

const appName = app.name[lang as keyof typeof app.name];

const BASE_COLOR = '#FFFBF0';
const ACCENT_COLOR = '#ED4CA5';
const TEXT_COLOR = '#4A4A4A';
const OTHER_COLOR = '#FFF2D9';
---

<Layout title={`${appName} - A money log for people who gave up on budgeting apps`} description="A simple money logging app with no balance tracking, no categories, and no pressure to manage everything perfectly. Just record what you spent and keep going." ogImage="/images/ogp-moneymemo.png">
  <Header />

  <main class="memo-page bg-[#FFFBF0] text-[#4A4A4A] overflow-hidden zen-maru selection:bg-[#ED4CA5] selection:text-white">

    <!-- ① First View -->
    <section class="relative pt-12 pb-16 md:pt-20 md:pb-24 px-6 bg-[#FFFBF0]">
      <!-- Background decorations -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <!-- Thin outline circles -->
        <div class="absolute top-[8%] right-[6%] w-[380px] h-[380px] border border-[#ED4CA5]/15 rounded-full"></div>
        <div class="absolute top-[14%] right-[10%] w-[300px] h-[300px] border border-[#E8B94F]/20 rounded-full"></div>
        <div class="absolute bottom-[-6%] left-[4%] w-[220px] h-[220px] border border-[#ED4CA5]/10 rounded-full"></div>
      </div>

      <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-12 md:gap-16 relative z-10">
        <!-- Left Text Area -->
        <div class="flex-1 space-y-8 text-center md:text-left w-full flex flex-col items-center md:items-start">
          <div class="space-y-5 flex flex-col items-center md:items-start">
            <!-- Catchphrase -->
            <p class="text-lg md:text-xl font-bold tracking-wide leading-relaxed text-[#4A4A4A]">
              A <span class="text-[#ED4CA5]">money log</span> for people<br class="md:hidden" /> who gave up on budgeting apps
            </p>

            <!-- Title -->
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-widest pt-2">
              <span class="text-[#ED4CA5]">Money</span><span class="text-[#4A4A4A]">Memo</span>
            </h1>
          </div>

          <!-- Subcopy -->
          <div class="space-y-5 pt-2">
            <p class="text-lg md:text-xl leading-relaxed text-[#ED4CA5] font-bold tracking-wide">
              Less effort. Easier to keep going.
            </p>
            <p class="text-base md:text-lg leading-loose text-[#857E74] font-medium tracking-wide">
              Just enter what you spent and how much.<br />No balance tracking, no categories,<br class="md:hidden" /> no pressure to manage everything perfectly.
            </p>
          </div>

          <!-- Download Badges -->
          <div class="flex flex-wrap items-center justify-center md:justify-start gap-4 pt-4">
            <!-- App Store -->
            <a href="https://apps.apple.com/us/app/%E3%81%8A%E3%81%8B%E3%81%AD%E3%83%A1%E3%83%A2/id6767521020?itscg=30200&itsct=apps_box_badge&mttnsubad=6767521020" target="_blank" rel="noopener noreferrer" class="hover:opacity-80 active:scale-98 transition-all duration-200 inline-block" style="display: inline-block;">
              <img src="https://toolbox.marketingtools.apple.com/api/v2/badges/download-on-the-app-store/black/en-us?releaseDate=1779148800" alt="Download on the App Store" style="width: 200px; height: 74px; vertical-align: middle; object-fit: contain;" />
            </a>
            <!-- Google Play (Coming Soon) -->
            <div class="inline-flex items-center bg-[#0a0a0a] text-white rounded-xl px-4 py-2 border border-gray-800 opacity-60 cursor-not-allowed select-none transition-all duration-300" style="width: 200px; height: 74px; justify-content: center; gap: 10px;">
              <svg class="w-8 h-8 text-gray-400" viewBox="0 0 24 24" fill="currentColor">
                <path d="M5,3.5C5,3.2 5.2,3 5.5,3C5.7,3 5.9,3.1 6,3.2L19.5,11.2C20.1,11.5 20.1,12.5 19.5,12.8L6,20.8C5.9,20.9 5.7,21 5.5,21C5.2,21 5,20.8 5,20.5V3.5M7,6V18L14.5,12L7,6Z" />
              </svg>
              <div class="text-left leading-tight">
                <div class="text-[9px] font-bold text-gray-400 uppercase tracking-wider">GET IT ON</div>
                <div class="text-base font-black tracking-tight text-gray-200">Google Play</div>
                <div class="text-[10px] text-[#ED4CA5] font-bold tracking-wider mt-0.5">COMING SOON</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Image Area -->
        <div class="flex-1 relative flex justify-center w-full mt-8 md:mt-0">
          <div class="relative w-[240px] md:w-[290px] lg:w-[320px]">
            <div class="absolute -inset-7 z-0 rounded-[3rem] border border-dashed border-[#ED4CA5]/20 bg-white/20 rotate-3"></div>
            <div class="absolute -left-12 top-12 z-0 hidden h-24 w-24 rounded-full border border-[#E8B94F]/30 bg-[#FFF2D9]/30 md:block"></div>
            <div class="bg-black p-2 md:p-2.5 rounded-[2.5rem] relative z-10">
              <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-6 bg-black rounded-b-3xl z-20"></div>
              <img src="/images/fv_screenshot.webp" alt="Money Memo App Screen" class="w-full h-auto rounded-[2rem] border border-gray-200" />
            </div>
            <img src="/images/basic2x.webp" alt="Pig Character" class="w-24 h-24 md:w-28 md:h-28 absolute -bottom-4 -right-8 md:-right-12 z-20 animate-[float_6s_ease-in-out_infinite]" />
          </div>
        </div>
      </div>
    </section>

    <!-- ② Empathy Section -->
    <section class="py-20 md:py-28 px-6 relative bg-[#FFF2D9]">
      <!-- Background decorations -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <span class="ghost-num absolute top-8 left-4 md:left-10 text-[5rem] md:text-[8rem]">01</span>
        <div class="absolute bottom-[10%] right-[-6%] w-[280px] h-[280px] border border-[#ED4CA5]/10 rounded-full"></div>
      </div>

      <div class="max-w-4xl mx-auto text-center space-y-12 relative z-10">

        <div class="space-y-5">
          <div class="flex items-center justify-center gap-3">
            <span class="w-10 h-px bg-[#ED4CA5]/40"></span>
            <span class="w-1.5 h-1.5 rotate-45 bg-[#ED4CA5]/70"></span>
            <p class="text-xs font-bold tracking-[0.3em] text-[#ED4CA5]">REASON</p>
            <span class="w-1.5 h-1.5 rotate-45 bg-[#ED4CA5]/70"></span>
            <span class="w-10 h-px bg-[#ED4CA5]/40"></span>
          </div>
          <h2 class="text-2xl md:text-3xl font-bold leading-relaxed text-[#4A4A4A]">
            <span class="marker-pink">If budgeting never stuck,<br class="md:hidden" /> it's probably not your fault.</span>
          </h2>
        </div>

        <div class="flex justify-center -mt-4">
          <img src="/images/question2x.webp" alt="Questioning Pig" class="w-20 h-20 md:w-24 md:h-24 opacity-80" />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 md:gap-6 pt-2 text-left">
          <div class="bg-white p-6 md:p-7 rounded-2xl border border-[#F0EBDD] shadow-warm memo-card relative overflow-hidden hover:-translate-y-1 transition-transform duration-300">
            <div class="flex items-center gap-4 relative z-10">
              <span class="w-9 h-9 rounded-full bg-[#FFE9F4] border border-[#ED4CA5]/25 text-[#ED4CA5] flex items-center justify-center font-bold text-sm shrink-0">01</span>
              <p class="text-base md:text-lg font-bold text-[#4A4A4A]">Starting strong, then fading</p>
            </div>
          </div>
          <div class="bg-white p-6 md:p-7 rounded-2xl border border-[#F0EBDD] shadow-warm memo-card relative overflow-hidden hover:-translate-y-1 transition-transform duration-300">
            <div class="flex items-center gap-4 relative z-10">
              <span class="w-9 h-9 rounded-full bg-[#FFE9F4] border border-[#ED4CA5]/25 text-[#ED4CA5] flex items-center justify-center font-bold text-sm shrink-0">02</span>
              <p class="text-base md:text-lg font-bold text-[#4A4A4A]">Categorizing feels like a chore</p>
            </div>
          </div>
          <div class="bg-white p-6 md:p-7 rounded-2xl border border-[#F0EBDD] shadow-warm memo-card relative overflow-hidden hover:-translate-y-1 transition-transform duration-300">
            <div class="flex items-center gap-4 relative z-10">
              <span class="w-9 h-9 rounded-full bg-[#FFE9F4] border border-[#ED4CA5]/25 text-[#ED4CA5] flex items-center justify-center font-bold text-sm shrink-0">03</span>
              <p class="text-base md:text-lg font-bold text-[#4A4A4A]">One small mismatch ruins it</p>
            </div>
          </div>
          <div class="bg-white p-6 md:p-7 rounded-2xl border border-[#F0EBDD] shadow-warm memo-card relative overflow-hidden hover:-translate-y-1 transition-transform duration-300">
            <div class="flex items-center gap-4 relative z-10">
              <span class="w-9 h-9 rounded-full bg-[#FFE9F4] border border-[#ED4CA5]/25 text-[#ED4CA5] flex items-center justify-center font-bold text-sm shrink-0">04</span>
              <p class="text-base md:text-lg font-bold text-[#4A4A4A]">One day, you just stop opening the app</p>
            </div>
          </div>
        </div>

        <div class="pt-6 relative inline-block">
          <p class="text-xl md:text-2xl font-bold text-[#ED4CA5] leading-relaxed">
            So we cut down on<br class="md:hidden" /> the "proper management" part.
          </p>
        </div>
      </div>
    </section>

    <!-- ? Features -->
    <section class="py-20 md:py-28 px-6 relative bg-[#FFFBF0]">
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <span class="ghost-num absolute top-8 right-4 md:right-10 text-[5rem] md:text-[8rem]">02</span>
        <div class="absolute bottom-[-10%] right-[8%] w-[360px] h-[360px] border border-[#ED4CA5]/10 rounded-full"></div>
        <div class="absolute bottom-[-4%] right-[14%] w-[260px] h-[260px] border border-[#E8B94F]/15 rounded-full"></div>
      </div>

      <div class="max-w-6xl mx-auto space-y-16 relative z-10">
        <div class="space-y-5 text-center">
          <div class="flex items-center justify-center gap-3">
            <span class="w-10 h-px bg-[#ED4CA5]/40"></span>
            <span class="w-1.5 h-1.5 rotate-45 bg-[#ED4CA5]/70"></span>
            <p class="text-xs font-bold tracking-[0.3em] text-[#ED4CA5]">FEATURES</p>
            <span class="w-1.5 h-1.5 rotate-45 bg-[#ED4CA5]/70"></span>
            <span class="w-10 h-px bg-[#ED4CA5]/40"></span>
          </div>
          <h2 class="text-2xl md:text-3xl font-bold leading-relaxed text-[#4A4A4A]">
            <span class="marker-yellow">Money Memo is a simple app<br />built around one thing:<br />being easy to keep going.</span>
          </h2>
        </div>

        <div class="space-y-14 md:space-y-16">
          <div class="feature-zigzag">
            <div class="screen-frame">
              <div class="screen-crop screen-crop-input">
                <img src="/images/screen_input.webp" alt="Money Memo input screen with only an item and amount field" loading="lazy" />
              </div>
            </div>
            <div class="feature-copy-block">
              <p class="feature-number">01</p>
              <h3>Just enter what you spent and how much</h3>
              <p>No confusing fields. When you notice an expense, you can log it in about three seconds.</p>
            </div>
          </div>

          <div class="feature-zigzag">
            <div class="feature-copy-block">
              <p class="feature-number">02</p>
              <h3>A note by itself, without an amount, is fine too</h3>
              <p>A short note like ?starting to save today? can be a record too. You do not have to force every entry into an amount.</p>
            </div>
            <div class="screen-frame">
              <div class="screen-crop screen-crop-input">
                <img src="/images/screen_memo.webp" alt="Money Memo note-only input screen without an amount" loading="lazy" />
              </div>
            </div>
          </div>

          <div class="feature-zigzag">
            <div class="screen-frame">
              <div class="screen-crop screen-crop-list">
                <img src="/images/usecase_oshikatsu.webp" alt="Money Memo list screen with no balance row shown" loading="lazy" />
              </div>
            </div>
            <div class="feature-copy-block">
              <p class="feature-number">03</p>
              <h3>No balance display ? a small mismatch never stops you</h3>
              <p>There is no balance to fix. You can leave the stressful work of correcting numbers behind.</p>
            </div>
          </div>

          <div class="feature-zigzag">
            <div class="feature-copy-block">
              <p class="feature-number">04</p>
              <h3>No categories ? nothing to decide, just log it</h3>
              <p>You do not have to wonder which category something belongs in. Write it in your own words and move on.</p>
            </div>
            <div class="screen-frame">
              <div class="screen-crop screen-crop-list">
                <img src="/images/usecase_yuru.webp" alt="Money Memo list screen with hard-to-categorize everyday entries" loading="lazy" />
              </div>
            </div>
          </div>
        </div>

        <p class="text-center text-xl md:text-2xl font-bold text-[#ED4CA5] leading-relaxed">
          Rather than "managing perfectly",<br />we value keeping the habit going.
        </p>
      </div>
    </section>
    <!-- ? Use Cases -->
    <section class="py-20 md:py-28 px-6 relative bg-[#FFF2D9]">
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <span class="ghost-num absolute top-8 left-4 md:left-10 text-[5rem] md:text-[8rem]">03</span>
        <div class="absolute top-[15%] right-[-8%] w-[320px] h-[320px] border border-[#ED4CA5]/10 rounded-full"></div>
      </div>

      <div class="max-w-6xl mx-auto space-y-14 relative z-10">
        <div class="text-center space-y-5">
          <div class="flex items-center justify-center gap-3">
            <span class="w-10 h-px bg-[#ED4CA5]/40"></span>
            <span class="w-1.5 h-1.5 rotate-45 bg-[#ED4CA5]/70"></span>
            <p class="text-xs font-bold tracking-[0.3em] text-[#ED4CA5]">USE CASES</p>
            <span class="w-1.5 h-1.5 rotate-45 bg-[#ED4CA5]/70"></span>
            <span class="w-10 h-px bg-[#ED4CA5]/40"></span>
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-[#4A4A4A] leading-relaxed">
            <span class="marker-pink">How to use it</span>
          </h2>
          <p class="text-base md:text-lg text-[#857E74] font-medium pt-2">
            You do not have to track everything. You can casually record only the expenses you care about.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-7">
          <article class="persona-card">
            <div class="space-y-4">
              <p class="persona-label">01</p>
              <h3>Memo only fandom and hobby spending</h3>
              <p>Skip the full household budget. Just keep a light record of the money you spent on what you love.</p>
            </div>
            <div class="screen-crop screen-crop-list persona-screen">
              <img src="/images/usecase_oshikatsu.webp" alt="Money Memo list for fandom and hobby spending" loading="lazy" />
            </div>
          </article>

          <article class="persona-card">
            <div class="space-y-4">
              <p class="persona-label">02</p>
              <h3>A relaxed money memo for people who quit budgeting</h3>
              <p>No need to be strict. This is the loosest way to memo only the expenses that caught your attention.</p>
            </div>
            <div class="screen-crop screen-crop-list persona-screen">
              <img src="/images/usecase_yuru.webp" alt="Money Memo list for relaxed everyday spending notes" loading="lazy" />
            </div>
          </article>

          <article class="persona-card">
            <div class="space-y-4">
              <p class="persona-label">03</p>
              <h3>For a first allowance log</h3>
              <p>The input is simple, so it works well as a first money record that parents can recommend to teens.</p>
            </div>
            <div class="screen-crop screen-crop-list persona-screen">
              <img src="/images/usecase_okozukai.webp" alt="Money Memo list for an allowance log" loading="lazy" />
            </div>
          </article>
        </div>
      </div>
    </section>
    <!-- ⑤ Not trying too hard -->
    <section class="py-24 md:py-32 px-6 relative bg-[#FFFBF0]">
      <!-- Background decorations -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <span class="ghost-num absolute top-8 right-4 md:right-10 text-[5rem] md:text-[8rem]">04</span>
        <div class="absolute bottom-[8%] left-[-6%] w-[280px] h-[280px] border border-[#ED4CA5]/10 rounded-full"></div>
        <!-- Quote decorations -->
        <span class="absolute top-[26%] left-[6%] md:left-[16%] text-7xl md:text-8xl font-black text-[#ED4CA5]/[0.08] leading-none select-none">“</span>
        <span class="absolute bottom-[16%] right-[6%] md:right-[16%] text-7xl md:text-8xl font-black text-[#ED4CA5]/[0.08] leading-none select-none">”</span>
      </div>
      <div class="max-w-3xl mx-auto text-center relative z-10">
        <div class="space-y-5">
          <div class="flex items-center justify-center gap-3">
            <span class="w-10 h-px bg-[#ED4CA5]/40"></span>
            <span class="w-1.5 h-1.5 rotate-45 bg-[#ED4CA5]/70"></span>
            <p class="text-xs font-bold tracking-[0.3em] text-[#ED4CA5]">PHILOSOPHY</p>
            <span class="w-1.5 h-1.5 rotate-45 bg-[#ED4CA5]/70"></span>
            <span class="w-10 h-px bg-[#ED4CA5]/40"></span>
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-[#4A4A4A] leading-relaxed">
            <span class="marker-pink">Keeping a record shouldn't<br class="md:hidden" /> take so much effort.</span>
          </h2>
        </div>
        <div class="space-y-8 text-lg md:text-xl text-[#857E74] leading-loose font-medium pt-12">
          <p>Logging every expense.<br />Sorting categories.<br />Balancing to the last cent.</p>
          <p>If you can do all that,<br class="md:hidden" /> there are more powerful apps out there.</p>
          <p class="text-xl md:text-2xl font-bold text-[#4A4A4A] pt-6 leading-relaxed">
            Money Memo is for the people<br />who found that too much to keep up with —<br />so we lowered the bar for recording<br class="md:hidden" /> as far as we could.
          </p>
        </div>
      </div>
    </section>

    <!-- ⑥ Fun -->
    <section class="py-20 md:py-28 px-6 relative bg-[#FFF2D9]">
      <!-- Background decorations -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <span class="ghost-num absolute top-8 left-4 md:left-10 text-[5rem] md:text-[8rem]">05</span>
        <div class="absolute bottom-[6%] left-[-8%] w-[300px] h-[300px] border border-[#ED4CA5]/10 rounded-full"></div>
      </div>

      <div class="max-w-5xl mx-auto space-y-14 relative z-10">

        <div class="flex flex-col justify-center items-center gap-5 text-center">
          <div class="flex items-center justify-center gap-3">
            <span class="w-10 h-px bg-[#ED4CA5]/40"></span>
            <span class="w-1.5 h-1.5 rotate-45 bg-[#ED4CA5]/70"></span>
            <p class="text-xs font-bold tracking-[0.3em] text-[#ED4CA5]">FUN</p>
            <span class="w-1.5 h-1.5 rotate-45 bg-[#ED4CA5]/70"></span>
            <span class="w-10 h-px bg-[#ED4CA5]/40"></span>
          </div>
          <h2 class="text-2xl md:text-3xl font-bold text-[#4A4A4A] leading-relaxed">
            <span class="marker-pink">A little bit of fun to keep you going.</span>
          </h2>
          <img src="/images/piggy_bank.png" alt="Piggy Bank" class="w-20 h-20 md:w-24 md:h-24 mt-4" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
          <div class="bg-white rounded-3xl p-6 md:p-7 text-center space-y-5 border border-[#F0EBDD] shadow-warm memo-card hover:-translate-y-1 transition-transform duration-300 group">
            <div class="overflow-hidden rounded-2xl border border-[#F0EBDD]">
              <img src="/images/proverb.webp" alt="Proverb Screen" class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="flex items-center justify-center gap-2">
              <span class="w-1 h-1 rotate-45 bg-[#ED4CA5]/60"></span>
              <h3 class="text-lg md:text-xl font-bold text-[#4A4A4A]">Money Proverbs</h3>
            </div>
          </div>
          <div class="bg-white rounded-3xl p-6 md:p-7 text-center space-y-5 border border-[#F0EBDD] shadow-warm memo-card hover:-translate-y-1 transition-transform duration-300 group">
            <div class="overflow-hidden rounded-2xl border border-[#F0EBDD]">
              <img src="/images/milestone_fun.webp" alt="Milestone Effect" class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="flex items-center justify-center gap-2">
              <span class="w-1 h-1 rotate-45 bg-[#ED4CA5]/60"></span>
              <h3 class="text-lg md:text-xl font-bold text-[#4A4A4A]">Streak Milestones</h3>
            </div>
            <p class="text-sm md:text-base text-[#857E74] font-medium leading-relaxed">
              On milestone days, the little character celebrates right along with you.
            </p>
          </div>
          <div class="bg-white rounded-3xl p-6 md:p-7 text-center space-y-5 border border-[#F0EBDD] shadow-warm memo-card hover:-translate-y-1 transition-transform duration-300 group">
            <div class="overflow-hidden rounded-2xl border border-[#F0EBDD]">
              <img src="/images/stats.webp" alt="Stats Screen" class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="flex items-center justify-center gap-2">
              <span class="w-1 h-1 rotate-45 bg-[#ED4CA5]/60"></span>
              <h3 class="text-lg md:text-xl font-bold text-[#4A4A4A]">Monthly & Yearly Stats</h3>
            </div>
          </div>
        </div>

        <div class="flex flex-wrap justify-center gap-3 text-sm md:text-base font-medium text-[#857E74]">
          <span class="bg-white px-5 py-2 rounded-full border border-[#F0EBDD] shadow-warm flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-[#ED4CA5]/70"></span>Dark Mode</span>
          <span class="bg-white px-5 py-2 rounded-full border border-[#F0EBDD] shadow-warm flex items-center gap-2"><span class="w-1 h-1 rounded-full bg-[#ED4CA5]/70"></span>Japanese & English</span>
