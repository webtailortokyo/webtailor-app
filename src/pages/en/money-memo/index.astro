---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import { apps } from '../../../data/apps';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const app = apps.find(a => a.id === 'money-memo')!;

const appName = app.name[lang as keyof typeof app.name];
const appDescription = app.description[lang as keyof typeof app.description];

const BASE_COLOR = '#FFFBF0';
const ACCENT_COLOR = '#ED4CA5';
const TEXT_COLOR = '#4A4A4A';
const OTHER_COLOR = '#FFF2D9';
---

<Layout title={`${appName} - The Money Memo for those who struggle to keep track`} description={appDescription} ogImage="/images/ogp-moneymemo.png">
  <Header />

  <main class="bg-[#FFFBF0] text-[#4A4A4A] overflow-hidden zen-maru selection:bg-[#ED4CA5] selection:text-white">
    
    <!-- ① First View -->
    <section class="relative pt-8 pb-12 md:pt-12 md:pb-16 px-6 bg-[#FFFBF0]">
      <!-- Background Decorations -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-[-10%] left-[-5%] w-[400px] h-[400px] bg-[#FFE2E2] rounded-[40%_60%_70%_30%/40%_50%_60%_50%] blur-3xl opacity-50"></div>
        <div class="absolute top-[20%] right-[-5%] w-[500px] h-[400px] bg-[#DBFCE7] rounded-[60%_40%_30%_70%/60%_30%_70%_40%] blur-3xl opacity-50"></div>
        <div class="absolute top-[60%] left-[20%] w-[300px] h-[300px] bg-[#FFF2D9] rounded-[30%_70%_70%_30%/30%_30%_70%_70%] blur-3xl opacity-60"></div>
        <div class="absolute top-[5%] left-[45%] md:left-[55%] -translate-x-1/2 w-64 h-64 bg-dots-pink opacity-50 -rotate-12 animate-[float_8s_ease-in-out_infinite]"></div>
        <div class="absolute bottom-[5%] right-[5%] w-72 h-72 bg-dots-green opacity-50 rotate-6 animate-[float_10s_ease-in-out_infinite_reverse]"></div>
      </div>

      <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-center gap-10 md:gap-16 relative z-10">
        <!-- Left Text Area -->
        <div class="flex-1 space-y-8 text-center w-full flex flex-col items-center">
          <div class="space-y-4 flex flex-col items-center">
            <div class="flex flex-col items-center space-y-2">
              <p class="text-xl md:text-2xl font-bold tracking-widest text-[#4A4A4A] uppercase">
                For those who struggle to <span class="text-[#ED4CA5]">keep going</span>
              </p>
              <svg width="240" height="20" viewBox="0 0 240 20" fill="none" class="hidden md:block">
                <path d="M10,0 C80,0 110,0 120,18 C130,0 160,0 230,0" stroke="#ED4CA5" stroke-width="2" fill="none" stroke-linecap="round"/>
              </svg>
              <svg width="180" height="15" viewBox="0 0 180 15" fill="none" class="md:hidden">
                <path d="M0,0 C60,0 85,0 90,14 C95,0 120,0 180,0" stroke="#ED4CA5" stroke-width="2" fill="none" stroke-linecap="round"/>
              </svg>
            </div>
            
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-black tracking-widest pt-2">
              <span class="text-[#ED4CA5]">Money</span><span class="text-[#4A4A4A]">Memo</span>
            </h1>
          </div>

          <div class="space-y-6 pt-2 text-center">
            <p class="text-xl md:text-2xl leading-loose text-[#4A4A4A] font-bold tracking-wide">
              For pocket money, lunch expenses,<br />or your hobbies.
            </p>
            <p class="text-base md:text-lg leading-relaxed text-[#757575] font-medium tracking-wide">
              Simple enough to keep going.<br />A money memo app you can use at your own pace.
            </p>
          </div>

          <!-- Download Badges -->
          <div class="flex flex-wrap items-center justify-center gap-4 pt-6">
            <!-- App Store -->
            <a href="https://apps.apple.com/us/app/%E3%81%8A%E3%81%8B%E3%81%AD%E3%83%A1%E3%83%A2/id6767521020?itscg=30200&itsct=apps_box_badge&mttnsubad=6767521020" target="_blank" rel="noopener noreferrer" class="hover:opacity-80 active:scale-98 transition-all duration-200 inline-block" style="display: inline-block;">
              <img src="https://toolbox.marketingtools.apple.com/api/v2/badges/download-on-the-app-store/black/en-us?releaseDate=1779148800" alt="Download on the App Store" style="width: 224px; height: 82px; vertical-align: middle; object-fit: contain;" />
            </a>
            <!-- Google Play (Coming Soon) -->
            <div class="inline-flex items-center bg-[#0a0a0a] text-white rounded-xl px-4 py-2 border border-gray-800 opacity-60 cursor-not-allowed select-none transition-all duration-300" style="width: 224px; height: 82px; justify-content: center; gap: 10px;">
              <svg class="w-8 h-8 text-gray-400" viewBox="0 0 24 24" fill="currentColor">
                <path d="M5,3.5C5,3.2 5.2,3 5.5,3C5.7,3 5.9,3.1 6,3.2L19.5,11.2C20.1,11.5 20.1,12.5 19.5,12.8L6,20.8C5.9,20.9 5.7,21 5.5,21C5.2,21 5,20.8 5,20.5V3.5M7,6V18L14.5,12L7,6Z" />
              </svg>
              <div class="text-left leading-tight">
                <div class="text-[9px] font-bold text-gray-400 uppercase tracking-wider">GET IT ON</div>
                <div class="text-base font-black tracking-tight text-gray-200">Google Play</div>
                <div class="text-[10px] text-[#ED4CA5] font-bold tracking-wider mt-0.5">COMING SOON</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Image Area -->
        <div class="flex-1 relative flex justify-center w-full mt-8 md:mt-0">
          <div class="relative w-[220px] md:w-[260px] lg:w-[280px]">
            <div class="bg-black p-2 md:p-2.5 rounded-[2.5rem] shadow-2xl relative">
              <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-6 bg-black rounded-b-3xl z-20"></div>
              <img src="/images/fv_screenshot.webp" alt="Money Memo App Screen" class="w-full h-auto rounded-[2rem] border border-gray-200" />
            </div>
            <img src="/images/basic2x.webp" alt="Pig Character" class="w-28 h-28 md:w-36 md:h-36 absolute -bottom-4 -right-10 md:-right-16 animate-[float_6s_ease-in-out_infinite]" />
          </div>
        </div>
      </div>
    </section>

    <!-- ② Empathy Section -->
    <section class="py-24 px-6 relative bg-white">
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-[10%] left-[-5%] w-[450px] h-[450px] bg-[#FFF2D9] rounded-[50%_50%_30%_70%/50%_70%_30%_50%] blur-3xl opacity-40"></div>
        <div class="absolute top-[10%] right-[5%] w-64 h-64 bg-dots-gray opacity-40 rotate-12 animate-[float_12s_ease-in-out_infinite]"></div>
      </div>

      <div class="max-w-4xl mx-auto text-center space-y-12 relative z-10">
        <div class="flex justify-center">
          <h2 class="text-3xl md:text-4xl font-bold leading-relaxed text-[#4A4A4A] relative z-10">
            <span class="marker-pink">Do your expense trackers<br class="md:hidden" /> end up like this?</span>
          </h2>
        </div>
        
        <div class="flex justify-center -mt-4">
          <img src="/images/question2x.webp" alt="Questioning Pig" class="w-24 h-24 md:w-28 md:h-28 opacity-80" />
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8 pt-4">
          <div class="bg-[#FFFBF0] p-8 rounded-3xl shadow-sm border border-gray-50">
            <p class="text-xl font-bold text-[#4A4A4A]">Only trying hard at the start</p>
          </div>
          <div class="bg-[#FFFBF0] p-8 rounded-3xl shadow-sm border border-gray-50">
            <p class="text-xl font-bold text-[#4A4A4A]">Categorizing is a hassle</p>
          </div>
          <div class="bg-[#FFFBF0] p-8 rounded-3xl shadow-sm border border-gray-50">
            <p class="text-xl font-bold text-[#4A4A4A]">Frustrated when off by 1 cent</p>
          </div>
          <div class="bg-[#FFFBF0] p-8 rounded-3xl shadow-sm border border-gray-50">
            <p class="text-xl font-bold text-[#4A4A4A]">Eventually stop opening the app</p>
          </div>
        </div>

        <div class="pt-8 relative inline-block">
          <p class="text-2xl md:text-3xl font-bold text-[#ED4CA5] leading-relaxed">
            That's why we reduced the<br class="md:hidden" /> "strict management" aspect.
          </p>
        </div>
      </div>
    </section>

    <!-- ③ Features -->
    <section class="py-24 px-6 relative bg-[#FFFBF0]">
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute bottom-[0%] right-[5%] w-[400px] h-[400px] bg-[#DBFCE7] rounded-[70%_30%_50%_50%/30%_50%_50%_70%] blur-3xl opacity-40"></div>
        <div class="absolute top-[10%] right-[5%] w-64 h-64 bg-dots-pink opacity-40 -rotate-6 animate-[float_9s_ease-in-out_infinite_reverse]"></div>
        <div class="absolute bottom-[10%] left-[5%] w-64 h-64 bg-dots-gray opacity-40 rotate-12 animate-[float_11s_ease-in-out_infinite]"></div>
      </div>

      <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-16 relative z-10">
        <div class="flex-1 space-y-10 order-2 md:order-1">
          <div class="flex md:block justify-center text-center md:text-left">
             <h2 class="text-3xl md:text-4xl font-bold leading-relaxed text-[#4A4A4A] relative z-10">
               <span class="marker-yellow">Money Memo is a simple app<br />focused on<br />"making it easy to continue".</span>
             </h2>
          </div>
          <ul class="space-y-6 text-xl text-[#4A4A4A] font-medium">
            <li class="flex items-center gap-4 bg-white p-4 rounded-2xl shadow-sm border border-gray-50">
              <span class="text-[#ED4CA5] text-2xl">●</span> Just enter 'Item' and 'Amount'
            </li>
            <li class="flex items-center gap-4 bg-white p-4 rounded-2xl shadow-sm border border-gray-50">
              <span class="text-[#ED4CA5] text-2xl">●</span> Text-only notes without money are OK
            </li>
            <li class="flex items-center gap-4 bg-white p-4 rounded-2xl shadow-sm border border-gray-50">
              <span class="text-[#ED4CA5] text-2xl">●</span> Designed to make you want to open it
            </li>
          </ul>
          <div class="text-center md:text-left pt-4">
            <p class="text-2xl font-bold text-[#ED4CA5] leading-relaxed">
              Rather than "managing perfectly",<br />we value building the habit first.
            </p>
          </div>
        </div>
        <div class="flex-1 order-1 md:order-2 flex justify-center items-center w-full relative min-h-[350px] md:min-h-[450px]">
          <!-- Card 1: Simple Input -->
          <div class="absolute z-10 transform -rotate-6 -translate-x-12 -translate-y-12 hover:z-40 hover:scale-105 hover:-rotate-2 transition-all duration-300">
             <div class="bg-white p-2 md:p-3 rounded-3xl shadow-xl border border-gray-100 w-48 md:w-64">
                <img src="/images/simple_input.webp" alt="Simple Input" class="w-full h-auto rounded-2xl" />
             </div>
          </div>
          <!-- Card 2: Only Memo -->
          <div class="absolute z-20 transform rotate-3 translate-x-12 -translate-y-4 hover:z-40 hover:scale-105 hover:rotate-1 transition-all duration-300">
             <div class="bg-white p-2 md:p-3 rounded-3xl shadow-xl border border-gray-100 w-44 md:w-56">
                <img src="/images/only_memo.webp" alt="Memo Only" class="w-full h-auto rounded-2xl" />
             </div>
          </div>
          <!-- Card 3: Milestone -->
          <div class="absolute z-30 transform -rotate-3 -translate-x-4 translate-y-24 md:translate-y-28 hover:z-40 hover:scale-105 hover:rotate-0 transition-all duration-300">
             <div class="bg-white p-2 md:p-3 rounded-3xl shadow-xl border border-gray-100 w-52 md:w-64">
                <img src="/images/milestone.webp" alt="Fun to continue" class="w-full h-auto rounded-2xl" />
             </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ④ Use Cases -->
    <section class="py-24 px-6 relative bg-white">
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-[10%] left-[10%] w-[500px] h-[500px] bg-[#FFE2E2] rounded-[30%_70%_70%_30%/30%_30%_70%_70%] blur-3xl opacity-30"></div>
        <div class="absolute top-[5%] right-[5%] w-64 h-64 bg-dots-green opacity-40 rotate-12 animate-[float_11s_ease-in-out_infinite]"></div>
      </div>

      <div class="max-w-5xl mx-auto space-y-16 relative z-10">
        <div class="text-center">
          <h2 class="text-3xl md:text-4xl font-bold text-[#4A4A4A] relative z-10 leading-relaxed">
            <span class="marker-pink">How to use it</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          
          <div class="bg-[#FFFBF0] rounded-[2.5rem] p-10 md:p-14 space-y-8 shadow-sm relative overflow-hidden group border border-gray-100">
            <div class="absolute top-0 right-0 w-40 h-40 bg-gradient-to-bl from-[#DBFCE7] to-transparent opacity-50 rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
            <div class="text-center md:text-left">
              <h3 class="text-2xl md:text-3xl font-bold text-[#4A4A4A] relative z-10">
                <span class="marker-green">As a Pocket Money Tracker</span>
              </h3>
            </div>
            <ul class="space-y-4 text-lg text-[#4A4A4A] font-medium relative z-10">
              <li class="flex items-start gap-3">
                <span class="text-[#05DF72] mt-1 text-xl">✓</span>
                Track immediately with your phone
              </li>
              <li class="flex items-start gap-3">
                <span class="text-[#05DF72] mt-1 text-xl">✓</span>
                No worries about losing it like paper
              </li>
              <li class="flex items-start gap-3">
                <span class="text-[#05DF72] mt-1 text-xl">✓</span>
                Easy to continue with just Item and Amount
              </li>
            </ul>
            <p class="text-xl font-bold text-[#4A4A4A] pt-4 relative z-10 text-center md:text-left leading-relaxed">
              Even if it's not perfect,<br />we value the act of recording first.
            </p>
          </div>

          <div class="bg-[#FFFBF0] rounded-[2.5rem] p-10 md:p-14 space-y-8 shadow-sm relative overflow-hidden group border border-gray-100">
            <div class="absolute top-0 right-0 w-40 h-40 bg-gradient-to-bl from-[#FFE2E2] to-transparent opacity-50 rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
            <div class="text-center md:text-left">
              <h3 class="text-2xl md:text-3xl font-bold text-[#4A4A4A] relative z-10">
                <span class="marker-pink">To Track Specific Expenses</span>
              </h3>
            </div>
            <ul class="grid grid-cols-2 gap-4 text-base md:text-lg text-[#4A4A4A] font-medium relative z-10">
              <li class="bg-white px-4 py-3 rounded-xl shadow-sm text-center border border-gray-50">Weekday Lunches</li>
              <li class="bg-white px-4 py-3 rounded-xl shadow-sm text-center border border-gray-50">Hobbies / Fandom</li>
              <li class="bg-white px-4 py-3 rounded-xl shadow-sm text-center border border-gray-50">Entertainment</li>
              <li class="bg-white px-4 py-3 rounded-xl shadow-sm text-center border border-gray-50">Subscriptions</li>
            </ul>
            <div class="space-y-4 text-xl font-bold text-[#4A4A4A] pt-4 relative z-10 text-center md:text-left">
              <p>"Maybe I'm spending too much..."</p>
              <p>You can easily track<br />just those specific expenses.</p>
              <p>You don't have to manage everything.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ⑤ 習慣化 -->
    <section class="py-32 px-6 relative bg-[#FFFBF0]">
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-[-10%] left-[-10%] w-[400px] h-[400px] bg-[#FFE2E2] rounded-[40%_60%_70%_30%/40%_50%_60%_50%] blur-3xl opacity-30"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[450px] h-[450px] bg-[#DBFCE7] rounded-[60%_40%_30%_70%/60%_30%_70%_40%] blur-3xl opacity-30"></div>
        <div class="absolute top-[5%] left-[5%] w-64 h-64 bg-dots-gray opacity-40 rotate-6 animate-[float_10s_ease-in-out_infinite]"></div>
        <div class="absolute bottom-[5%] right-[5%] w-64 h-64 bg-dots-pink opacity-40 -rotate-12 animate-[float_12s_ease-in-out_infinite_reverse]"></div>
      </div>
      <div class="max-w-3xl mx-auto text-center relative z-10">
        <div class="flex justify-center">
          <h2 class="text-3xl md:text-4xl font-bold text-[#4A4A4A] tracking-wider relative z-10 leading-relaxed">
            <span class="marker-pink">Building the habit, step by step</span>
          </h2>
        </div>
        <div class="space-y-8 text-xl md:text-2xl text-[#757575] leading-loose font-medium pt-12">
          <p>We live in an age where AI can write for us.</p>
          <p>But what to write,<br />depends entirely on your own experiences.</p>
          <p>That's why noting down<br />even small things matters.</p>
          <p class="text-2xl md:text-3xl font-bold text-[#4A4A4A] pt-8 leading-relaxed">
            We hope "Money Memo" becomes<br />your gateway to the habit of recording.
          </p>
        </div>
      </div>
    </section>

    <!-- ⑥ 楽しさ -->
    <section class="py-24 px-6 relative bg-white">
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-[20%] right-[10%] w-[500px] h-[500px] bg-[#DBFCE7] rounded-[70%_30%_50%_50%/30%_50%_50%_70%] blur-3xl opacity-30"></div>
        <div class="absolute top-[10%] left-[5%] w-80 h-80 bg-dots-pink opacity-30 -rotate-12 animate-[float_13s_ease-in-out_infinite_reverse]"></div>
      </div>

      <div class="max-w-5xl mx-auto space-y-16 relative z-10">
        
        <div class="flex flex-col justify-center items-center gap-6 text-center">
          <h2 class="text-3xl md:text-4xl font-bold text-[#4A4A4A] relative z-10 leading-relaxed">
            <span class="marker-pink">A little bit of fun to keep you going.</span>
          </h2>
          <img src="/images/piggy_bank.png" alt="Piggy Bank" class="w-24 h-24 md:w-28 md:h-28 mt-4 animate-[float_6s_ease-in-out_infinite]" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-[#FFFBF0] rounded-3xl p-6 md:p-8 text-center space-y-6 shadow-sm border border-gray-50 hover:-translate-y-1 transition-transform group">
            <div class="overflow-hidden rounded-2xl border border-gray-100">
              <img src="/images/proverb.webp" alt="Proverb Screen" class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <h3 class="text-xl font-bold text-[#4A4A4A]">Money Proverbs</h3>
          </div>
          <div class="bg-[#FFFBF0] rounded-3xl p-6 md:p-8 text-center space-y-6 shadow-sm border border-gray-50 hover:-translate-y-1 transition-transform group">
            <div class="overflow-hidden rounded-2xl border border-gray-100">
              <img src="/images/milestone_fun.webp" alt="Milestone Effect" class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <h3 class="text-xl font-bold text-[#4A4A4A]">Streak Milestones</h3>
          </div>
          <div class="bg-[#FFFBF0] rounded-3xl p-6 md:p-8 text-center space-y-6 shadow-sm border border-gray-50 hover:-translate-y-1 transition-transform group">
            <div class="overflow-hidden rounded-2xl border border-gray-100">
              <img src="/images/stats.webp" alt="Stats Screen" class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <h3 class="text-xl font-bold text-[#4A4A4A]">Monthly & Yearly Stats</h3>
          </div>
        </div>

        <div class="flex flex-wrap justify-center gap-4 text-lg font-medium text-[#757575]">
          <span class="bg-white px-6 py-2 rounded-full shadow-sm border border-gray-100">Dark Mode</span>
          <span class="bg-white px-6 py-2 rounded-full shadow-sm border border-gray-100">Japanese & English</span>
          <span class="bg-white px-6 py-2 rounded-full shadow-sm border border-gray-100">Multi-Currency (Dollar, Euro, etc.)</span>
        </div>

        <div class="text-center pt-8">
          <p class="text-2xl font-bold text-[#ED4CA5] leading-relaxed">
            Keep inputs simple,<br />but make it genuinely fun.
          </p>
        </div>
      </div>
    </section>

    <!-- ⑦ 開発ストーリー -->
    <section class="py-24 px-6 relative bg-[#FFFBF0]">
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-[10%] left-[5%] w-64 h-64 bg-dots-green opacity-40 -rotate-12 animate-[float_10s_ease-in-out_infinite]"></div>
      </div>
      <div class="max-w-4xl mx-auto relative z-10">
        <div class="bg-white rounded-[3rem] p-10 md:p-16 relative shadow-sm border border-[#FFF2D9]">
          <div class="absolute -top-6 left-1/2 -translate-x-1/2 md:translate-x-0 md:left-16 bg-white px-8 py-3 rounded-full shadow-sm border border-gray-100 font-bold text-[#ED4CA5] text-lg uppercase tracking-wider">
            Our Story
          </div>
          <div class="space-y-8 text-lg md:text-xl text-[#4A4A4A] leading-loose font-medium pt-6">
            <p>It started with my child's pocket money book.</p>
            <p>But forgetting to record made the balance off. Even saying 'rough estimates are fine', the discrepancy itself became stressful.</p>
            <p>That's why Money Memo focuses on 'continuing'.</p>
            <p>Rather than managing perfectly, start by building the recording habit.<br />Instead of overcoming weakness with sheer effort, we made it a form you can continue.</p>
            <p class="text-2xl font-bold pt-4 text-center md:text-left leading-relaxed">
              That is why<br class="md:hidden" /> "Money Memo" was born.
            </p>
          </div>
          <div class="mt-12 flex justify-center md:absolute md:bottom-8 md:right-8 md:mt-0">
            <img src="/images/wizpiggy2x.webp" alt="Wizard Pig" class="w-24 h-24 md:w-36 md:h-36 opacity-80 hover:-translate-y-2 transition-transform duration-300" />
          </div>
        </div>
      </div>
    </section>

    <!-- ⑧ CTA -->
