---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AppCard from '../components/AppCard.astro';
import { useTranslations, getLangFromUrl } from '../i18n/utils';
import { apps } from '../data/apps';
import StorySection from '../components/StorySection.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout>
  <Header />
  
  <main class="flex-grow">
    <!-- Hero Section -->
    <section class="relative py-48 px-4 overflow-hidden min-h-[70vh] flex items-center">
      <!-- Background Image -->
      <div class="absolute inset-0 z-0">
        <img src="/images/hero-bg.webp" alt="Background" class="w-full h-full object-cover" />
      </div>

      <div class="relative z-10 max-w-5xl mx-auto text-center">
        <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-8 leading-tight">
          {t('hero.title').split('\n').map((line, i) => (
            <>
              <span class={i === 0 ? "text-[#333]" : "text-[#3585c7]"}>
                {line}
              </span>
              {i === 0 && <br />}
            </>
          ))}
        </h1>
        <div class="h-1.5 w-24 bg-gradient-to-r from-[#3585c7] to-[#70c6dd] mx-auto mb-10 rounded-full opacity-60"></div>
        <p class="text-2xl md:text-4xl text-[#333] font-bold leading-relaxed max-w-3xl mx-auto font-subtitle bg-white/50 px-8 py-2 rounded-full inline-block shadow-[0_0_20px_rgba(255,255,255,0.8)]">
          {t('hero.description')}
        </p>
      </div>
    </section>
    <StorySection />
    <!-- Apps List Section -->
    <section class="py-20 px-4 bg-gray-50">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16 space-y-4">
          <h2 class="text-4xl font-bold text-[#3585c7] tracking-tight">
            {t('apps.title')}
          </h2>
          <p class="text-gray-500 font-medium">{lang === 'ja' ? 'シンプルで使いやすいツールを。' : 'Simple tools for your daily life.'}</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {apps.map(app => (
            <AppCard app={app} />
          ))}
          
          <!-- Future Placeholder Card -->
          <div class="group border-2 border-dashed border-gray-200 rounded-3xl p-8 flex flex-col items-center justify-center text-center gap-4 opacity-50 bg-white/50">
            <div class="w-16 h-16 rounded-2xl bg-gray-50 border border-gray-100 flex items-center justify-center">
              <span class="text-2xl font-bold text-gray-300">?</span>
            </div>
            <p class="text-gray-400 font-bold uppercase tracking-widest text-xs">More apps coming soon</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
