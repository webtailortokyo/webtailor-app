---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const BASE_COLOR = '#FFFBF0';
const ACCENT_COLOR = '#ED4CA5';
const TEXT_COLOR = '#4A4A4A';
const OTHER_COLOR = '#FFF2D9';
---

<Layout title="おかねメモ - 続かない人のためのお金メモ" description="おこづかい帳にも、ランチ代や趣味の記録にも。まずは記録を続けることを大切にした、やさしいお金メモアプリです。">
  <Header />

  <main class="bg-[#FFFBF0] text-[#4A4A4A] overflow-hidden zen-maru selection:bg-[#ED4CA5] selection:text-white">
    
    <!-- ① ファーストビュー -->
    <section class="relative pt-8 pb-12 md:pt-12 md:pb-16 px-6 bg-[#FFFBF0]">
      <!-- 背景装飾 -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-[-10%] left-[-5%] w-[400px] h-[400px] bg-[#FFE2E2] rounded-[40%_60%_70%_30%/40%_50%_60%_50%] blur-3xl opacity-50"></div>
        <div class="absolute top-[20%] right-[-5%] w-[500px] h-[400px] bg-[#DBFCE7] rounded-[60%_40%_30%_70%/60%_30%_70%_40%] blur-3xl opacity-50"></div>
        <div class="absolute top-[60%] left-[20%] w-[300px] h-[300px] bg-[#FFF2D9] rounded-[30%_70%_70%_30%/30%_30%_70%_70%] blur-3xl opacity-60"></div>
        <!-- ドット装飾 (中央上・右下) -->
        <div class="absolute top-[5%] left-[45%] md:left-[55%] -translate-x-1/2 w-64 h-64 bg-dots-pink opacity-50 -rotate-12 animate-[float_8s_ease-in-out_infinite]"></div>
        <div class="absolute bottom-[5%] right-[5%] w-72 h-72 bg-dots-green opacity-50 rotate-6 animate-[float_10s_ease-in-out_infinite_reverse]"></div>
      </div>

      <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-center gap-10 md:gap-16 relative z-10">
        <!-- 左テキストエリア -->
        <div class="flex-1 space-y-8 text-center w-full flex flex-col items-center">
          <div class="space-y-4 flex flex-col items-center">
            <!-- 続かない人のための -->
            <div class="flex flex-col items-center space-y-2">
              <p class="text-2xl md:text-3xl font-bold tracking-widest text-[#4A4A4A]">
                続かない<span class="text-[#ED4CA5]">人</span>のための
              </p>
              <svg width="240" height="20" viewBox="0 0 240 20" fill="none" class="hidden md:block">
                <path d="M10,0 C80,0 110,0 120,18 C130,0 160,0 230,0" stroke="#ED4CA5" stroke-width="2" fill="none" stroke-linecap="round"/>
              </svg>
              <svg width="180" height="15" viewBox="0 0 180 15" fill="none" class="md:hidden">
                <path d="M0,0 C60,0 85,0 90,14 C95,0 120,0 180,0" stroke="#ED4CA5" stroke-width="2" fill="none" stroke-linecap="round"/>
              </svg>
            </div>
            
            <!-- タイトル -->
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-black tracking-widest pt-2">
              <span class="text-[#ED4CA5]">おかね</span><span class="text-[#4A4A4A]">メモ</span>
            </h1>
          </div>

          <!-- サブコピー -->
          <div class="space-y-6 pt-2 text-center">
            <p class="text-xl md:text-2xl leading-loose text-[#4A4A4A] font-bold tracking-wide">
              おこづかい帳にも、<br />ランチ代や趣味の記録にも。
            </p>
            <p class="text-base md:text-lg leading-relaxed text-[#757575] font-medium tracking-wide">
              シンプルだから続けやすい、<br />自分のペースで使えるお金メモアプリです。
            </p>
          </div>

          <!-- ストアボタン -->
          <div class="flex flex-wrap justify-center gap-4 pt-4">
            <a href="#" class="inline-flex items-center justify-center bg-black text-white px-6 py-3 rounded-xl font-bold hover:scale-105 transition-transform shadow-lg group">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 mr-3 fill-white" viewBox="0 0 24 24"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.1 2.48-1.34.03-1.77-.79-3.29-.79-1.53 0-1.99.77-3.27.82-1.31.05-2.32-1.32-3.15-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.24-1.99 1.1-3.15-1.04.04-2.31.69-3.05 1.56-.66.77-1.25 1.97-1.1 3.12 1.15.09 2.3-.6 3.05-1.53z"/></svg>
              <div class="text-left">
                <div class="text-[0.65rem] font-medium leading-none mb-1 text-gray-300">App Store</div>
                <div class="text-sm leading-none">からダウンロード</div>
              </div>
            </a>
            
            <a href="#" class="inline-flex items-center justify-center bg-black text-white px-6 py-3 rounded-xl font-bold hover:scale-105 transition-transform shadow-lg group">
              <img src="https://upload.wikimedia.org/wikipedia/commons/d/d0/Google_Play_Arrow_logo.svg" alt="Google Play" class="w-7 h-7 mr-3 object-contain" />
              <div class="text-left">
                <div class="text-[0.65rem] font-medium leading-none mb-1 text-gray-300">Google Play</div>
                <div class="text-sm leading-none">で手に入れよう</div>
              </div>
            </a>
          </div>
        </div>

        <!-- 右画像エリア -->
        <div class="flex-1 relative flex justify-center w-full mt-8 md:mt-0">
          <div class="relative w-[220px] md:w-[260px] lg:w-[280px]">
            <!-- スマホモックアップ風 -->
            <div class="bg-black p-3 md:p-4 rounded-[3rem] shadow-2xl relative">
              <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-6 bg-black rounded-b-3xl z-20"></div> <!-- ノッチ -->
              <img src="https://placehold.co/600x1250/F8F9FA/4A4A4A?text=App+Screen" alt="おかねメモ アプリ画面" class="w-full h-auto rounded-[2.2rem] border border-gray-200" />
            </div>
            <!-- basic2x.webp ブタキャラクター -->
            <img src="/images/basic2x.webp" alt="ブタのキャラクター" class="w-28 h-28 md:w-36 md:h-36 absolute -bottom-4 -right-10 md:-right-16 animate-[float_6s_ease-in-out_infinite]" />
          </div>
        </div>
      </div>
    </section>

    <!-- ② 共感セクション -->
    <section class="py-24 px-6 relative bg-white">
      <!-- 背景装飾 -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-[10%] left-[-5%] w-[450px] h-[450px] bg-[#FFF2D9] rounded-[50%_50%_30%_70%/50%_70%_30%_50%] blur-3xl opacity-40"></div>
        <div class="absolute top-[10%] right-[5%] w-64 h-64 bg-dots-gray opacity-40 rotate-12 animate-[float_12s_ease-in-out_infinite]"></div>
      </div>

      <div class="max-w-4xl mx-auto text-center space-y-12 relative z-10">
        
        <div class="flex justify-center">
          <h2 class="text-3xl md:text-4xl font-bold leading-relaxed text-[#4A4A4A] relative z-10">
            <span class="marker-pink">家計簿、<br class="md:hidden" />こんな風になっていませんか？</span>
          </h2>
        </div>
        
        <!-- タイトルの直下にキャラクター配置 (1.3倍ほど大きく) -->
        <div class="flex justify-center -mt-4">
          <img src="/images/question2x.webp" alt="はてなブタ" class="w-24 h-24 md:w-28 md:h-28 opacity-80" />
        </div>
        
        <!-- ホバーアニメーション削除 -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8 pt-4">
          <div class="bg-[#FFFBF0] p-8 rounded-3xl shadow-sm border border-gray-50">
            <p class="text-xl font-bold text-[#4A4A4A]">最初だけ頑張る</p>
          </div>
          <div class="bg-[#FFFBF0] p-8 rounded-3xl shadow-sm border border-gray-50">
            <p class="text-xl font-bold text-[#4A4A4A]">カテゴリ分けが面倒</p>
          </div>
          <div class="bg-[#FFFBF0] p-8 rounded-3xl shadow-sm border border-gray-50">
            <p class="text-xl font-bold text-[#4A4A4A]">1円ズレるとイヤになる</p>
          </div>
          <div class="bg-[#FFFBF0] p-8 rounded-3xl shadow-sm border border-gray-50">
            <p class="text-xl font-bold text-[#4A4A4A]">気づくとアプリを開かなくなる</p>
          </div>
        </div>

        <div class="pt-8 relative inline-block">
          <p class="text-2xl md:text-3xl font-bold text-[#ED4CA5] leading-relaxed">
            だから、<br class="md:hidden" />「ちゃんと管理する」を減らしました。
          </p>
        </div>
      </div>
    </section>

    <!-- ③ おかねメモの特徴 -->
    <section class="py-24 px-6 relative bg-[#FFFBF0]">
      <!-- 背景装飾 -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute bottom-[0%] right-[5%] w-[400px] h-[400px] bg-[#DBFCE7] rounded-[70%_30%_50%_50%/30%_50%_50%_70%] blur-3xl opacity-40"></div>
        <div class="absolute top-[10%] right-[5%] w-64 h-64 bg-dots-pink opacity-40 -rotate-6 animate-[float_9s_ease-in-out_infinite_reverse]"></div>
        <div class="absolute bottom-[10%] left-[5%] w-64 h-64 bg-dots-gray opacity-40 rotate-12 animate-[float_11s_ease-in-out_infinite]"></div>
      </div>

      <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-16 relative z-10">
        <div class="flex-1 space-y-10 order-2 md:order-1">
          <div class="flex md:block justify-center text-center md:text-left">
             <h2 class="text-3xl md:text-4xl font-bold leading-relaxed text-[#4A4A4A] relative z-10">
               <span class="marker-yellow">おかねメモは、<br />「続けやすさ」を大事にした<br />シンプルなお金メモです。</span>
             </h2>
          </div>
          <!-- 元の白背景デザインに戻す -->
          <ul class="space-y-6 text-xl text-[#4A4A4A] font-medium">
            <li class="flex items-center gap-4 bg-white p-4 rounded-2xl shadow-sm border border-gray-50">
              <span class="text-[#ED4CA5] text-2xl">●</span> 入力は「項目」と「金額」だけ
            </li>
            <li class="flex items-center gap-4 bg-white p-4 rounded-2xl shadow-sm border border-gray-50">
              <span class="text-[#ED4CA5] text-2xl">●</span> お金を入れないメモだけの記録もOK
            </li>
            <li class="flex items-center gap-4 bg-white p-4 rounded-2xl shadow-sm border border-gray-50">
              <span class="text-[#ED4CA5] text-2xl">●</span> また開きたくなる工夫も
            </li>
          </ul>
          <div class="text-center md:text-left pt-4">
            <p class="text-2xl font-bold text-[#ED4CA5] leading-relaxed">
              「ちゃんと管理する」より、<br />まずは続けることを大切にしました。
            </p>
          </div>
        </div>
        <div class="flex-1 order-1 md:order-2 flex justify-center w-full relative pt-10 md:pt-0">
          <div class="bg-black p-2 md:p-3 rounded-[2.5rem] shadow-xl transform rotate-3 hover:rotate-0 transition-transform duration-500 w-full max-w-xs relative z-10">
             <div class="absolute top-0 left-1/2 -translate-x-1/2 w-24 h-5 bg-black rounded-b-2xl z-20"></div>
             <img src="https://placehold.co/600x1200/ffffff/4A4A4A?text=Simple+Input" alt="シンプル入力画面" class="w-full h-auto rounded-[2rem] border border-gray-100" />
          </div>
          <!-- 貯金箱ブタ (スマホは右下、PCは左上へ) -->
          <img src="/images/piggy_bank.png" alt="貯金箱" class="w-28 h-28 absolute -bottom-4 -right-4 md:-top-12 md:-left-12 md:bottom-auto md:right-auto z-20 object-contain drop-shadow-md animate-[float_6s_ease-in-out_infinite]" />
        </div>
      </div>
    </section>

    <!-- ④ 用途提案 -->
    <section class="py-24 px-6 relative bg-white">
      <!-- 背景装飾 -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-[10%] left-[10%] w-[500px] h-[500px] bg-[#FFE2E2] rounded-[30%_70%_70%_30%/30%_30%_70%_70%] blur-3xl opacity-30"></div>
        <div class="absolute top-[5%] right-[5%] w-64 h-64 bg-dots-green opacity-40 rotate-12 animate-[float_11s_ease-in-out_infinite]"></div>
      </div>

      <div class="max-w-5xl mx-auto space-y-16 relative z-10">
        <div class="text-center">
          <h2 class="text-3xl md:text-4xl font-bold text-[#4A4A4A] relative z-10 leading-relaxed">
            <span class="marker-pink">こんな使い方ができます</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          
          <!-- 4-1 おこづかい帳として -->
          <div class="bg-[#FFFBF0] rounded-[2.5rem] p-10 md:p-14 space-y-8 shadow-sm relative overflow-hidden group border border-gray-100">
            <div class="absolute top-0 right-0 w-40 h-40 bg-gradient-to-bl from-[#DBFCE7] to-transparent opacity-50 rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
            <div class="text-center md:text-left">
              <h3 class="text-2xl md:text-3xl font-bold text-[#4A4A4A] relative z-10">
                <span class="marker-green">おこづかい帳として</span>
              </h3>
            </div>
            <ul class="space-y-4 text-lg text-[#4A4A4A] font-medium relative z-10">
              <li class="flex items-start gap-3">
                <span class="text-[#05DF72] mt-1 text-xl">✓</span>
                スマホだから、買った時にすぐ記録できる
              </li>
              <li class="flex items-start gap-3">
                <span class="text-[#05DF72] mt-1 text-xl">✓</span>
                紙みたいに失くす心配がない
              </li>
              <li class="flex items-start gap-3">
                <span class="text-[#05DF72] mt-1 text-xl">✓</span>
                「項目」と「金額」だけだから続けやすい
              </li>
            </ul>
            <p class="text-xl font-bold text-[#4A4A4A] pt-4 relative z-10 text-center md:text-left leading-relaxed">
              完璧じゃなくても、<br />まずは記録することを大切にしました。
            </p>
          </div>

          <!-- 4-2 気になる出費の記録にも -->
          <div class="bg-[#FFFBF0] rounded-[2.5rem] p-10 md:p-14 space-y-8 shadow-sm relative overflow-hidden group border border-gray-100">
            <div class="absolute top-0 right-0 w-40 h-40 bg-gradient-to-bl from-[#FFE2E2] to-transparent opacity-50 rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
            <div class="text-center md:text-left">
              <h3 class="text-2xl md:text-3xl font-bold text-[#4A4A4A] relative z-10">
                <span class="marker-pink">気になる出費の記録にも</span>
              </h3>
            </div>
            <ul class="grid grid-cols-2 gap-4 text-base md:text-lg text-[#4A4A4A] font-medium relative z-10">
              <li class="bg-white px-4 py-3 rounded-xl shadow-sm text-center border border-gray-50">平日のランチ代</li>
              <li class="bg-white px-4 py-3 rounded-xl shadow-sm text-center border border-gray-50">推し活のお金</li>
              <li class="bg-white px-4 py-3 rounded-xl shadow-sm text-center border border-gray-50">趣味の出費</li>
              <li class="bg-white px-4 py-3 rounded-xl shadow-sm text-center border border-gray-50">サブスク管理</li>
            </ul>
            <div class="space-y-4 text-xl font-bold text-[#4A4A4A] pt-4 relative z-10 text-center md:text-left">
              <p>「なんとなく使いすぎてるかも」</p>
              <p>そんな出費だけを、<br />気軽に記録できます。</p>
              <p>全部を管理しなくてもOKです。</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ⑤ 記録する習慣を、少しずつ -->
    <section class="py-32 px-6 relative bg-[#FFFBF0]">
      <!-- 背景装飾 -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-[-10%] left-[-10%] w-[400px] h-[400px] bg-[#FFE2E2] rounded-[40%_60%_70%_30%/40%_50%_60%_50%] blur-3xl opacity-30"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[450px] h-[450px] bg-[#DBFCE7] rounded-[60%_40%_30%_70%/60%_30%_70%_40%] blur-3xl opacity-30"></div>
        <div class="absolute top-[5%] left-[5%] w-64 h-64 bg-dots-gray opacity-40 rotate-6 animate-[float_10s_ease-in-out_infinite]"></div>
        <div class="absolute bottom-[5%] right-[5%] w-64 h-64 bg-dots-pink opacity-40 -rotate-12 animate-[float_12s_ease-in-out_infinite_reverse]"></div>
      </div>
      <div class="max-w-3xl mx-auto text-center relative z-10">
        <div class="flex justify-center">
          <h2 class="text-3xl md:text-4xl font-bold text-[#4A4A4A] tracking-wider relative z-10 leading-relaxed">
            <span class="marker-pink">記録する習慣を、少しずつ</span>
          </h2>
        </div>
        <div class="space-y-8 text-xl md:text-2xl text-[#757575] leading-loose font-medium pt-12">
          <p>AIで文章は作れる時代。</p>
          <p>でも、<br />何を書くかは、<br />自分の経験次第です。</p>
          <p>だから、<br />小さなことでもメモする。</p>
          <p class="text-2xl md:text-3xl font-bold text-[#4A4A4A] pt-8 leading-relaxed">
            「おかねメモ」は、<br />記録する習慣の入口に<br class="md:hidden" />なれたらと思っています。
          </p>
        </div>
      </div>
    </section>

    <!-- ⑥ 楽しく続けるための機能 -->
    <section class="py-24 px-6 relative bg-white">
      <!-- 背景装飾 -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-[20%] right-[10%] w-[500px] h-[500px] bg-[#DBFCE7] rounded-[70%_30%_50%_50%/30%_50%_50%_70%] blur-3xl opacity-30"></div>
        <div class="absolute top-[10%] left-[5%] w-80 h-80 bg-dots-pink opacity-30 -rotate-12 animate-[float_13s_ease-in-out_infinite_reverse]"></div>
      </div>

      <div class="max-w-5xl mx-auto space-y-16 relative z-10">
        
        <!-- タイトルとブタさんを縦並びに -->
        <div class="flex flex-col justify-center items-center gap-6 text-center">
          <h2 class="text-3xl md:text-4xl font-bold text-[#4A4A4A] relative z-10 leading-relaxed">
            <span class="marker-pink">続けるための、ちょっとした楽しさも。</span>
          </h2>
          <img src="/images/joy2x.webp" alt="喜ぶブタ" class="w-20 h-20 md:w-24 md:h-24 animate-bounce" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="bg-[#FFFBF0] rounded-3xl p-8 text-center space-y-6 shadow-sm border border-gray-50 hover:-translate-y-1 transition-transform">
            <img src="https://placehold.co/400x400/F8F9FA/4A4A4A?text=Proverb" alt="ことわざ表示画面" class="w-full h-48 object-cover rounded-2xl border border-gray-100" />
            <h3 class="text-xl font-bold text-[#4A4A4A]">お金にまつわることわざ</h3>
          </div>
          <div class="bg-[#FFFBF0] rounded-3xl p-8 text-center space-y-6 shadow-sm border border-gray-50 hover:-translate-y-1 transition-transform">
            <img src="https://placehold.co/400x400/F8F9FA/4A4A4A?text=Milestone" alt="マイルストーン演出" class="w-full h-48 object-cover rounded-2xl border border-gray-100" />
            <h3 class="text-xl font-bold text-[#4A4A4A]">記録日数のマイルストーン</h3>
          </div>
          <div class="bg-[#FFFBF0] rounded-3xl p-8 text-center space-y-6 shadow-sm border border-gray-50 hover:-translate-y-1 transition-transform">
            <img src="https://placehold.co/400x400/F8F9FA/4A4A4A?text=Stats" alt="集計画面" class="w-full h-48 object-cover rounded-2xl border border-gray-100" />
            <h3 class="text-xl font-bold text-[#4A4A4A]">月ごと・年ごとの集計</h3>
          </div>
        </div>

        <!-- 3つ対応項目 (元の白背景に戻す) -->
        <div class="flex flex-wrap justify-center gap-4 text-lg font-medium text-[#757575]">
          <span class="bg-white px-6 py-2 rounded-full shadow-sm border border-gray-100">ダークモード対応</span>
          <span class="bg-white px-6 py-2 rounded-full shadow-sm border border-gray-100">日本語 / English 対応</span>
          <span class="bg-white px-6 py-2 rounded-full shadow-sm border border-gray-100">円 / ドル / ユーロ 対応</span>
        </div>

        <div class="text-center pt-8">
          <p class="text-2xl font-bold text-[#ED4CA5] leading-relaxed">
            入力はシンプルに。<br />でも、続ける楽しさは少しだけ。
          </p>
        </div>
      </div>
    </section>

    <!-- ⑦ 開発ストーリー -->
    <section class="py-24 px-6 relative bg-[#FFFBF0]">
      <!-- 背景装飾 -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
